{
  "name": "quan-ly-can-tin-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "electron-vite build",
    "preview": "electron-vite preview",
    "electron:pack": "electron-builder",
    "electron:pack:mac": "electron-builder --mac --arm64 --x64",
    "electron:pack:win": "electron-builder --win --x64 --arm64"
  },
  "build": {
    "appId": "com.nousresearch.quanlycantin",
    "productName": "QuanLyCanTin",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist-electron/**/*",
      "dist/renderer/**/*"
    ],
    "mac": {
      "target": [
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64", "arm64"] }
      ]
    },
    "portable": {
      "artifactName": "QuanLyCanTin-0.1.0-windows-${arch}-portable.exe"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@tanstack/react-query": "^5.45.1",
    "antd": "^5.18.1",
    "axios": "^1.7.2",
    "dayjs": "^1.11.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.2",
    "react-router-dom": "^6.23.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/electron": "^1.4.38",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "31.0.2",
    "electron-builder": "24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
