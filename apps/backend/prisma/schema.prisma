generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  WAREHOUSE
}

enum PaymentMethod {
  CASH
  TRANSFER
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @db.VarChar(50)
  passwordHash String   @db.VarChar(255)
  fullName     String   @db.VarChar(100)
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  orders                Order[]
  inventoryTransactions InventoryTransaction[]

  @@map("users")
}

model CustomerGroup {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(100)
  note      String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  customers Customer[]

  @@map("customer_groups")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  fullName  String   @db.VarChar(100)
  groupId   String?  @db.Uuid
  phone     String?  @db.VarChar(20)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  group  CustomerGroup? @relation(fields: [groupId], references: [id])
  orders Order[]

  @@map("customers")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(100)
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  products Product[]

  @@map("categories")
}

model Unit {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(50)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  products Product[]

  // Đơn vị lớn hơn (VD: Thùng → Gói)
  conversionsFrom UnitConversion[] @relation("fromUnit")
  // Đơn vị nhỏ hơn
  conversionsTo   UnitConversion[] @relation("toUnit")

  @@map("units")
}

model UnitConversion {
  id         String  @id @default(uuid()) @db.Uuid
  productId  String  @db.Uuid
  fromUnitId String  @db.Uuid
  toUnitId   String  @db.Uuid
  factor     Decimal @db.Decimal(12, 4) // 1 fromUnit = factor toUnit (VD: 1 Thùng = 30 Gói)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromUnit  Unit     @relation("fromUnit", fields: [fromUnitId], references: [id])
  toUnit    Unit     @relation("toUnit", fields: [toUnitId], references: [id])

  @@unique([productId, fromUnitId, toUnitId])
  @@map("unit_conversions")
}

model Product {
  id           String  @id @default(uuid()) @db.Uuid
  code         String  @unique @db.VarChar(30)
  name         String  @db.VarChar(150)
  categoryId   String? @db.Uuid
  unitId       String? @db.Uuid
  sellingPrice Decimal @db.Decimal(12, 2)
  costPrice    Decimal @db.Decimal(12, 2)
  currentStock Decimal @default(0) @db.Decimal(12, 2)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  category              Category?              @relation(fields: [categoryId], references: [id])
  unit                  Unit?                  @relation(fields: [unitId], references: [id])
  orderItems            OrderItem[]
  inventoryTransactions InventoryTransaction[]
  stockCountItems       StockCountItem[]
  unitConversions       UnitConversion[]

  @@map("products")
}

model Order {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(30)
  cashierId     String   @db.Uuid
  customerId    String?  @db.Uuid
  paymentMethod PaymentMethod
  totalComputed Decimal  @db.Decimal(14, 2)
  note          String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  cashier  User        @relation(fields: [cashierId], references: [id])
  customer Customer?   @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  inventoryTransactions InventoryTransaction[]

  @@map("orders")
}

model OrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  orderId         String  @db.Uuid
  productId       String  @db.Uuid
  quantity        Decimal @db.Decimal(12, 2)
  unitPrice       Decimal @db.Decimal(12, 2)
  costPriceAtSale Decimal @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum InventoryTransactionType {
  IN
  OUT
  ADJUSTMENT
  COUNT
}

model InventoryTransaction {
  id          String                   @id @default(uuid()) @db.Uuid
  type        InventoryTransactionType
  productId   String                   @db.Uuid
  quantity    Decimal                  @db.Decimal(12, 2)
  stockBefore Decimal                  @db.Decimal(12, 2)
  stockAfter  Decimal                  @db.Decimal(12, 2)
  orderId     String?                  @db.Uuid
  referenceNo String?                @db.VarChar(50)
  reason      String?
  createdBy   String                   @db.Uuid
  createdAt   DateTime                 @default(now()) @db.Timestamptz(6)

  product         Product @relation(fields: [productId], references: [id])
  createdByUser   User    @relation(fields: [createdBy], references: [id])
  order           Order?  @relation(fields: [orderId], references: [id])

  @@map("inventory_transactions")
}

model StockCount {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(30)
  note      String?
  createdBy String   @db.Uuid
  countedAt DateTime @default(now()) @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  items StockCountItem[]

  @@map("stock_counts")
}

model StockCountItem {
  id           String  @id @default(uuid()) @db.Uuid
  stockCountId String  @db.Uuid
  productId    String  @db.Uuid
  expectedQty  Decimal @db.Decimal(12, 2)
  actualQty    Decimal @db.Decimal(12, 2)
  difference   Decimal @db.Decimal(12, 2)
  note         String?

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("stock_count_items")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tableName String   @db.VarChar(50)
  recordId  String   @db.VarChar(50)
  action    String   @db.VarChar(20)
  oldValue  Json?
  newValue  Json?
  userId    String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("audit_logs")
}
