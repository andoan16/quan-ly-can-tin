generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  WAREHOUSE
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum OrderStatus {
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @db.VarChar(50)
  passwordHash String   @db.VarChar(255)
  fullName     String   @db.VarChar(100)
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  orders                Order[]
  inventoryTransactions InventoryTransaction[]
  performanceReports    ProductPerformanceReport[]
  topupTransactions     TopupTransaction[]
  stockCounts          StockCount[]
  feedbacks            Feedback[]

  @@map("users")
}

model CustomerGroup {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(100)
  note      String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  customers Customer[]

  @@map("customer_groups")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  fullName  String   @db.VarChar(100)
  groupId   String?  @db.Uuid
  phone     String?  @db.VarChar(20)
  isActive  Boolean  @default(true)
  // Số dư tài khoản căn tin (nhận tiền từ người thân)
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  group     CustomerGroup?     @relation(fields: [groupId], references: [id])
  orders    Order[]
  topups    TopupTransaction[]

  @@map("customers")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(100)
  prefix    String   @unique @db.VarChar(10) // VD: "BM" cho Bánh mì → product code = BM000001
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  products Product[]

  @@map("categories")
}

model Unit {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(50)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  products    Product[] // ĐVT cơ bản
  bundleProducts Product[] @relation("bundleUnit") // ĐVT đóng gói (Thùng, Lốc)

  @@map("units")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique @db.VarChar(30)
  name         String   @db.VarChar(150)
  categoryId   String?  @db.Uuid
  unitId       String?  @db.Uuid
  sellingPrice Decimal  @db.Decimal(12, 2)
  costPrice    Decimal  @db.Decimal(12, 2)
  currentStock Decimal  @default(0) @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  // Bundle fields: sản phẩm đóng gói (Thùng, Lốc) trỏ về sản phẩm cơ bản (Gói, Chai)
  parentProductId String? @db.Uuid
  factor       Decimal? @db.Decimal(12, 4) // 1 Thùng = factor Gói (VD: 30)
  bundleUnitId String?  @db.Uuid       // ĐVT đóng gói (Thùng, Lốc)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  category              Category?               @relation(fields: [categoryId], references: [id])
  unit                  Unit?                   @relation(fields: [unitId], references: [id])
  bundleUnit            Unit?                   @relation("bundleUnit", fields: [bundleUnitId], references: [id])
  parentProduct         Product?                @relation("productVariants", fields: [parentProductId], references: [id])
  variants              Product[]               @relation("productVariants")
  orderItems            OrderItem[]
  inventoryTransactions InventoryTransaction[]
  stockCountItems       StockCountItem[]

  @@index([parentProductId])
  @@index([categoryId])
  @@map("products")
}

model Order {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(30)
  cashierId     String   @db.Uuid
  customerId    String?  @db.Uuid
  paymentMethod PaymentMethod @default(CASH) // giữ cho backward-compat, luôn CASH
  status        OrderStatus @default(COMPLETED)
  totalComputed Decimal  @db.Decimal(14, 2)
  // Số dư tài khoản trước/sau khi trừ
  balanceBefore Decimal? @db.Decimal(14, 2)
  balanceAfter  Decimal? @db.Decimal(14, 2)
  note          String?
  cancelledAt   DateTime? @db.Timestamptz(6)
  cancelledBy   String?  @db.Uuid
  cancelReason  String?  @db.VarChar(500)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  cashier  User        @relation(fields: [cashierId], references: [id])
  customer Customer?   @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  inventoryTransactions InventoryTransaction[]

  @@index([createdAt])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  orderId         String  @db.Uuid
  productId       String  @db.Uuid
  quantity        Decimal @db.Decimal(12, 2)
  unitPrice       Decimal @db.Decimal(12, 2)
  costPriceAtSale Decimal @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([orderId])
  @@map("order_items")
}

enum InventoryTransactionType {
  IN
  OUT
  ADJUSTMENT
  COUNT
}

model InventoryTransaction {
  id          String                   @id @default(uuid()) @db.Uuid
  type        InventoryTransactionType
  productId   String                   @db.Uuid
  quantity    Decimal                  @db.Decimal(12, 2)
  stockBefore Decimal                  @db.Decimal(12, 2)
  stockAfter  Decimal                  @db.Decimal(12, 2)
  orderId     String?                  @db.Uuid
  referenceNo String?                @db.VarChar(50)
  reason      String?
  createdBy   String                   @db.Uuid
  createdAt   DateTime                 @default(now()) @db.Timestamptz(6)

  product         Product @relation(fields: [productId], references: [id])
  createdByUser   User    @relation(fields: [createdBy], references: [id])
  order           Order?  @relation(fields: [orderId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_transactions")
}

model StockCount {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(30)
  note      String?
  createdBy String   @db.Uuid
  countedAt DateTime? @db.Timestamptz(6) // null = chưa hoàn thành
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  createdByUser User            @relation(fields: [createdBy], references: [id])
  items         StockCountItem[]

  @@map("stock_counts")
}

model StockCountItem {
  id           String  @id @default(uuid()) @db.Uuid
  stockCountId String  @db.Uuid
  productId    String  @db.Uuid
  expectedQty  Decimal @db.Decimal(12, 2)
  actualQty    Decimal @db.Decimal(12, 2)
  difference   Decimal @db.Decimal(12, 2)
  note         String?

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("stock_count_items")
}

model ProductPerformanceReport {
  id          String                          @id @default(uuid()) @db.Uuid
  name        String                          @db.VarChar(200)
  from        DateTime?                       @db.Timestamptz(6)
  to          DateTime?                       @db.Timestamptz(6)
  categoryId  String?                         @db.Uuid
  totalRevenue Decimal                         @db.Decimal(14, 2)
  totalCost   Decimal                         @db.Decimal(14, 2)
  totalProfit Decimal                         @db.Decimal(14, 2)
  totalQuantity Decimal                        @db.Decimal(12, 2)
  totalOrders Int
  productCount Int
  createdBy   String                          @db.Uuid
  createdAt   DateTime                        @default(now()) @db.Timestamptz(6)

  items           ProductPerformanceReportItem[]
  createdByUser   User                           @relation(fields: [createdBy], references: [id])

  @@map("product_performance_reports")
}

model ProductPerformanceReportItem {
  id            String   @id @default(uuid()) @db.Uuid
  reportId      String   @db.Uuid
  productId     String   @db.Uuid
  productCode   String   @db.VarChar(30)
  productName   String   @db.VarChar(150)
  categoryName  String?  @db.VarChar(100)
  unitName      String?  @db.VarChar(50)
  totalQuantity Decimal  @db.Decimal(12, 2)
  totalRevenue  Decimal  @db.Decimal(14, 2)
  totalCost     Decimal  @db.Decimal(14, 2)
  totalProfit   Decimal  @db.Decimal(14, 2)
  profitMargin  Decimal  @db.Decimal(5, 2)
  orderCount    Int

  report ProductPerformanceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("product_performance_report_items")
}

enum FeedbackType {
  BUG
  IMPROVEMENT
}

enum FeedbackStatus {
  NEW
  DONE
}

model Feedback {
  id        String          @id @default(uuid()) @db.Uuid
  type      FeedbackType
  content   String          @db.Text
  status    FeedbackStatus  @default(NEW)
  createdBy String          @db.Uuid
  createdAt DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @db.Timestamptz(6)

  createdByUser User @relation(fields: [createdBy], references: [id])

  @@map("feedbacks")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tableName String   @db.VarChar(50)
  recordId  String   @db.VarChar(50)
  action    String   @db.VarChar(20)
  oldValue  Json?
  newValue  Json?
  userId    String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("audit_logs")
}

// Lịch sử nạp tiền vào tài khoản (người thân gửi vào)
model TopupTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @db.Uuid
  amount      Decimal  @db.Decimal(14, 2)   // số tiền nạp (luôn dương)
  balanceBefore Decimal @db.Decimal(14, 2)
  balanceAfter  Decimal @db.Decimal(14, 2)
  receivedFrom String? @db.VarChar(150)     // tên người thân gửi (VD: "Nguyễn Văn B - bố")
  note        String?
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  customer      Customer @relation(fields: [customerId], references: [id])
  createdByUser User     @relation(fields: [createdBy], references: [id])

  @@index([customerId])
  @@index([createdAt])
  @@map("topup_transactions")
}
